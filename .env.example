# Copy this file to .env.local and fill in the values from your Supabase
# project dashboard (Project Settings -> API).

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / "public" key (safe to expose in the browser; access is
# controlled by the Row Level Security policies in supabase/migrations).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public URL this app is served from. Used to build email confirmation /
# password reset redirect links. Set this to your production URL once
# deployed (e.g. https://mojmajstor.ba); localhost is fine for development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: only needed if you add server-side logic that must bypass Row
# Level Security (e.g. an admin panel). Never expose this to the browser.
# Not used anywhere in this codebase today.
# SUPABASE_SERVICE_ROLE_KEY=
